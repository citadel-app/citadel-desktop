{
  "name": "@citadel-app/desktop",
  "version": "1.2.2",
  "description": "Desktop shell for Citadel Workspace",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win --x64 --arm64",
    "build:mac": "electron-builder --mac --universal",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64 --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@citadel-app/app": "^1.2.3",
    "@citadel-app/core": "^1.2.3",
    "@citadel-app/ui": "^1.2.3",
    "better-sqlite3": "^12.6.2",
    "buffer": "^6.0.3",
    "chokidar": "^3.6.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.3",
    "pdfjs-dist": "^4.10.38",
    "simple-git": "^3.30.0",
    "systeminformation": "^5.30.7",
    "uuid": "^9.0.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
