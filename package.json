{
  "name": "@citadel-app/desktop",
  "version": "1.2.1",
  "description": "Desktop shell for Citadel Workspace",
  "main": "./out/main/index.js",
  "scripts": {
    "build": "electron-builder --dir",
    "build:win": "electron-builder --win --x64 --arm64",
    "build:mac": "electron-builder --mac --universal",
    "build:mac:arm64": "electron-builder --mac --arm64",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:linux": "electron-builder --linux --x64 --arm64",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@citadel-app/app": "^1.2.1",
    "@citadel-app/core": "^1.2.1",
    "@citadel-app/ui": "^1.2.1",
    "better-sqlite3": "^12.6.2",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
